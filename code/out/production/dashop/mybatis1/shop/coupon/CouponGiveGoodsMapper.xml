<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="CouponGiveGoodsMapper">

    <!--表名 -->
    <sql id="tableName">
		SHOP_COUPONGIVEGOODS
	</sql>

    <!-- 字段 -->
    <sql id="Field">
		COUPON_ID,	
		GIVEGOODS_ID,	
		GIVEGOODS_NUM,	
		COUPONGIVEGOODS_ID
	</sql>

    <!-- 字段值 -->
    <sql id="FieldValue">
		#{COUPON_ID},	
		#{GIVEGOODS_ID},	
		#{GIVEGOODS_NUM},	
		#{COUPONGIVEGOODS_ID}
	</sql>

    <!-- 新增-->
    <insert id="save" parameterType="pd">
        insert into
        <include refid="tableName"></include>
        (
        <include refid="Field"></include>
        ) values (
        <include refid="FieldValue"></include>
        )
    </insert>

    <!-- 删除-->
    <delete id="delete" parameterType="pd">
        delete from
        <include refid="tableName"></include>
        where
        COUPONGIVEGOODS_ID = #{COUPONGIVEGOODS_ID}
    </delete>

    <!-- 修改 -->
    <update id="edit" parameterType="pd">
        update
        <include refid="tableName"></include>
        set
        COUPON_ID = #{COUPON_ID},
        GIVEGOODS_ID = #{GIVEGOODS_ID},
        GIVEGOODS_NUM = #{GIVEGOODS_NUM},
        COUPONGIVEGOODS_ID = COUPONGIVEGOODS_ID
        where
        COUPONGIVEGOODS_ID = #{COUPONGIVEGOODS_ID}
    </update>

    <!-- 通过ID获取数据 -->
    <select id="findById" parameterType="pd" resultType="pd">
        select
        <include refid="Field"></include>
        from
        <include refid="tableName"></include>
        where
        COUPONGIVEGOODS_ID = #{COUPONGIVEGOODS_ID}
    </select>

    <!-- 列表 -->
    <select id="datalistPage" parameterType="page" resultType="pd">
		select
		a.COUPON_ID,
		a.GIVEGOODS_ID,
		a.GIVEGOODS_NUM,
		a.COUPONGIVEGOODS_ID,
		b.GOODS_NAME,
		b.GOODS_PIC,
        c.CATEGORY_NAME
		from
		SHOP_COUPONGIVEGOODS a,SHOP_GOODS b,SHOP_CATEGORY c
		where a.GIVEGOODS_ID = b.GOODS_ID and b.GOODS_CATEGORY = c.CATEGORY_ID
	</select>

    <!-- 列表(全部) -->
    <select id="listAll" parameterType="pd" resultType="pd">
        select
        <include refid="Field"></include>
        from
        <include refid="tableName"></include>
    </select>

    <!-- 批量删除 -->
    <delete id="deleteAll" parameterType="String">
        delete from
        <include refid="tableName"></include>
        where
        COUPONGIVEGOODS_ID in
        <foreach item="item" index="index" collection="array" open="(" separator="," close=")">
            #{item}
        </foreach>
    </delete>

    <!-- da -->
</mapper>