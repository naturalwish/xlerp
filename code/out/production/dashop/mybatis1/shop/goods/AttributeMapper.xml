<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="AttributeMapper">
	
	<!--表名 -->
	<sql id="tableName">
		SHOP_ATTRIBUTE
	</sql>
	
	<!-- 字段 -->
	<sql id="Field">
		GOODS_ID,	
		ATTRIBUTE,	
		ATTRIBUTENUM,	
		ATTRIBUTEPRICE,	
		MARKETPRICE,
		SECKILLPRICE,
		ATTRIBUTE_ID
	</sql>
	
	<!-- 字段值 -->
	<sql id="FieldValue">
		#{GOODS_ID},	
		#{ATTRIBUTE},	
		#{ATTRIBUTENUM},	
		#{ATTRIBUTEPRICE},	
		#{MARKETPRICE},
		#{SECKILLPRICE},
		#{ATTRIBUTE_ID}
	</sql>
	
	<!-- 新增-->
	<insert id="save" parameterType="pd">
		insert into 
	<include refid="tableName"></include>
		(
	<include refid="Field"></include>
		) values (
	<include refid="FieldValue"></include>
		)
	</insert>
	
	<!-- 删除-->
	<delete id="delete" parameterType="pd">
		delete from
		<include refid="tableName"></include>
		where 
			ATTRIBUTE_ID = #{ATTRIBUTE_ID}
	</delete>
	
	<!-- 修改 -->
	<update id="edit" parameterType="pd">
		update
		<include refid="tableName"></include>
		set 
			GOODS_ID = #{GOODS_ID},
			ATTRIBUTE = #{ATTRIBUTE},
			ATTRIBUTENUM = #{ATTRIBUTENUM},
			ATTRIBUTEPRICE = #{ATTRIBUTEPRICE},
			MARKETPRICE = #{MARKETPRICE},
		    SECKILLPRICE = #{SECKILLPRICE},
		    ATTRIBUTE_ID = ATTRIBUTE_ID
		where 
		ATTRIBUTE_ID = #{ATTRIBUTE_ID}
	</update>

	<!-- 修改 -->
	<update id="editNum" parameterType="pd">
		update
		<include refid="tableName"></include>
		set
		<if test="ADD_OR_REDUCE =='REDUCE' ">
			ATTRIBUTENUM = ATTRIBUTENUM - #{ATTRIBUTENUM},
		</if>
		<if test="ADD_OR_REDUCE =='ADD' ">
			ATTRIBUTENUM = ATTRIBUTENUM + #{ATTRIBUTENUM},
		</if>
		ATTRIBUTE_ID = ATTRIBUTE_ID
		where
		ATTRIBUTE_ID = #{ATTRIBUTE_ID}
	</update>

	<!-- 通过ID获取数据 -->
	<select id="findById" parameterType="pd" resultType="pd">
		select 
		<include refid="Field"></include>
		from 
		<include refid="tableName"></include>
		where 
			ATTRIBUTE_ID = #{ATTRIBUTE_ID}
	</select>

	<!-- 通过Goods_ID获取最少价钱的规格 -->
	<select id="findMinByGoods" parameterType="pd" resultType="string">
		select ifnull(min(attributeprice),0) as MINPRICE from shop_attribute where goods_id = #{pd.GOODS_ID} and ATTRIBUTENUM>0
	</select>

	<!-- 通过Goods_ID获取最低秒杀价钱的规格 -->
	<select id="findMinSecByGoods" parameterType="pd" resultType="string">
		select ifnull(min(SECKILLPRICE),0) as SECPRICE from shop_attribute where goods_id = #{pd.GOODS_ID} and ATTRIBUTENUM>0
	</select>
	
	<!-- 列表 -->
	<select id="datalistPage" parameterType="page" resultType="pd">
		select
		<include refid="Field"></include>
		from 
		<include refid="tableName"></include>
		where 
		GOODS_ID = #{pd.GOODS_ID}
		<if test="pd.keywords!= null and pd.keywords != ''"><!-- 关键词检索 -->
			and
				(
				<!--	根据需求自己加检索条件
					字段1 LIKE CONCAT(CONCAT('%', #{pd.keywords}),'%')
					 or 
					字段2 LIKE CONCAT(CONCAT('%', #{pd.keywords}),'%') 
				-->
				)
		</if>
		order by ATTRIBUTE_ID
	</select>
	
	<!-- 列表(全部) -->
	<select id="listAll" parameterType="pd" resultType="pd">
		select
		<include refid="Field"></include>
		from 
		<include refid="tableName"></include>
	</select>
	
	<!-- 批量删除 -->
	<delete id="deleteAll" parameterType="String">
		delete from
		<include refid="tableName"></include>
		where 
			ATTRIBUTE_ID in
		<foreach item="item" index="index" collection="array" open="(" separator="," close=")">
                 #{item}
		</foreach>
	</delete>

	<!-- 获取商品的总数量 -->
	<select id="getSumNum" parameterType="pd" resultType="int">
		select
			ifnull(sum(attributenum),0)
		from
		<include refid="tableName"></include>
		where goods_id = #{pd.GOODS_ID}
	</select>
	
	<!-- 查询明细总数 -->
	<select id="findCount" parameterType="pd" resultType="pd">
		select
			count(*) zs
		from 
			<include refid="tableName"></include>
		where
			GOODS_ID = #{GOODS_ID}
	</select>
	
	<!-- da -->
</mapper>