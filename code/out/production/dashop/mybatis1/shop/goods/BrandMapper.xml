<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="BrandMapper">
	
	<!--表名 -->
	<sql id="tableName">
		SHOP_BRAND
	</sql>
	
	<!-- 字段 -->
	<sql id="Field">
		BRAND_NAME,	
		BRAND_URL,	
		BRAND_DETAIL,	
		BRAND_ORDER,	
		BRAND_VISIBLE,	
		BRAND_ID
	</sql>
	
	<!-- 字段值 -->
	<sql id="FieldValue">
		#{BRAND_NAME},	
		#{BRAND_URL},	
		#{BRAND_DETAIL},	
		#{BRAND_ORDER},	
		#{BRAND_VISIBLE},	
		#{BRAND_ID}
	</sql>
	
	<!-- 新增-->
	<insert id="save" parameterType="pd">
		insert into 
	<include refid="tableName"></include>
		(
	<include refid="Field"></include>
		) values (
	<include refid="FieldValue"></include>
		)
	</insert>
	
	<!-- 删除-->
	<delete id="delete" parameterType="pd">
		delete from
		<include refid="tableName"></include>
		where 
			BRAND_ID = #{BRAND_ID}
	</delete>
	
	<!-- 修改 -->
	<update id="edit" parameterType="pd">
		update
		<include refid="tableName"></include>
		set 
			BRAND_NAME = #{BRAND_NAME},
			BRAND_URL = #{BRAND_URL},
			BRAND_DETAIL = #{BRAND_DETAIL},
			BRAND_ORDER = #{BRAND_ORDER},
			BRAND_VISIBLE = #{BRAND_VISIBLE},
		BRAND_ID = BRAND_ID
		where 
		BRAND_ID = #{BRAND_ID}
	</update>
	
	<!-- 通过ID获取数据 -->
	<select id="findById" parameterType="pd" resultType="pd">
		select 
		<include refid="Field"></include>
		from 
		<include refid="tableName"></include>
		where 
			BRAND_ID = #{BRAND_ID}
	</select>

	<!-- 通过Goods_ID获取最大的排序 -->
	<select id="findMaxOrder" parameterType="pd" resultType="int">
		select
			ifnull(MAX(BRAND_ORDER),0)
		from
		<include refid="tableName"></include>
	</select>
	
	<!-- 列表 -->
	<select id="datalistPage" parameterType="page" resultType="pd">
		select
		<include refid="Field"></include>
		from 
		<include refid="tableName"></include>
		where 1=1
		<if test="pd.keywords!= null and pd.keywords != ''"><!-- 关键词检索 -->
			and
				(
					BRAND_NAME LIKE CONCAT(CONCAT('%', #{pd.keywords}),'%')
					 or
					BRAND_URL LIKE CONCAT(CONCAT('%', #{pd.keywords}),'%')
				)
		</if>
	</select>
	
	<!-- 列表(全部) -->
	<select id="listAll" parameterType="pd" resultType="pd">
		select
		<include refid="Field"></include>
		from 
		<include refid="tableName"></include>
		order by brand_order
	</select>
	
	<!-- 批量删除 -->
	<delete id="deleteAll" parameterType="String">
		delete from
		<include refid="tableName"></include>
		where 
			BRAND_ID in
		<foreach item="item" index="index" collection="array" open="(" separator="," close=")">
                 #{item}
		</foreach>
	</delete>
	
	<!-- da -->
</mapper>