<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="InvoiceMapper">
	
	<!--表名 -->
	<sql id="tableName">
		SHOP_INVOICE
	</sql>
	
	<!-- 字段 -->
	<sql id="Field">
		CODE,	
		ORDER_ID,	
		ADDORDERTIME,	
		CONSIGNEE,	
		INVOICETIME,	
		STATUS,	
		OPERATOR,
		OPERATIONTIME,	
		INVOICE_ID
	</sql>
	
	<!-- 字段值 -->
	<sql id="FieldValue">
		#{CODE},	
		#{ORDER_ID},	
		#{ADDORDERTIME},	
		#{CONSIGNEE},	
		#{INVOICETIME},	
		#{STATUS},	
		#{OPERATOR},
		#{OPERATIONTIME},	
		#{INVOICE_ID}
	</sql>
	
	<!-- 新增-->
	<insert id="save" parameterType="pd">
		insert into 
	<include refid="tableName"></include>
		(
	<include refid="Field"></include>
		) values (
	<include refid="FieldValue"></include>
		)
	</insert>
	
	<!-- 删除-->
	<delete id="delete" parameterType="pd">
		delete from
		<include refid="tableName"></include>
		where 
			INVOICE_ID = #{INVOICE_ID}
	</delete>
	
	<!-- 修改 -->
	<update id="edit" parameterType="pd">
		update
		<include refid="tableName"></include>
		set
		<if test="CODE !=null and CODE !=''">
			CODE = #{CODE},
		</if>
		<if test="ORDER_ID !=null and ORDER_ID !=''">
			ORDER_ID = #{ORDER_ID},
		</if>
		<if test="ADDORDERTIME !=null and ADDORDERTIME !=''">
			ADDORDERTIME = #{ADDORDERTIME},
		</if>
		<if test="CONSIGNEE !=null and CONSIGNEE !=''">
			CONSIGNEE = #{CONSIGNEE},
		</if>
		<if test="INVOICETIME !=null and INVOICETIME !=''">
			INVOICETIME = #{INVOICETIME},
		</if>
		<if test="STATUS !=null and STATUS !=''">
			STATUS = #{STATUS},
		</if>
		<if test="OPERATOR !=null and OPERATOR !=''">
			OPERATOR = #{OPERATOR},
		</if>
		<if test="OPERATIONTIME !=null and OPERATIONTIME !=''">
			OPERATIONTIME = #{OPERATIONTIME},
		</if>
		INVOICE_ID = INVOICE_ID
		where 
		INVOICE_ID = #{INVOICE_ID}
	</update>

	<!-- 关闭发货单 -->
	<update id="close" parameterType="pd">
		update
		<include refid="tableName"></include>
		set
		STATUS = #{STATUS}
		where
		ORDER_ID = #{ORDER_ID}
	</update>
	
	<!-- 通过ID获取数据 -->
	<select id="findById" parameterType="pd" resultType="pd">
		select 
		<include refid="Field"></include>
		from 
		<include refid="tableName"></include>
		where 
			INVOICE_ID = #{INVOICE_ID}
	</select>
	
	<!-- 列表 -->
	<select id="datalistPage" parameterType="page" resultType="pd">
		select
		<include refid="Field"></include>
		from 
		<include refid="tableName"></include>
		where 1=1
		<if test="pd.keywords!= null and pd.keywords != ''"><!-- 关键词检索 -->
			and
				(
					CODE LIKE CONCAT(CONCAT('%', #{pd.keywords}),'%')
					 or
			        ORDER_ID LIKE CONCAT(CONCAT('%', #{pd.keywords}),'%')
				)
		</if>
		<if test="pd.STATUS!=null and pd.STATUS!=''">
			and STATUS=#{pd.STATUS}
		</if>
		<!-- 开始时间 -->
		<if test="pd.lastStart != null and pd.lastStart !=''">
			and INVOICETIME &gt;= #{pd.lastStart}
		</if>
		<!-- 结束时间 -->
		<if test="pd.lastEnd != null and pd.lastEnd !=''">
			and INVOICETIME &lt;= #{pd.lastEnd}
		</if>
		order by CODE desc
	</select>

	<!-- 列表(全部) -->
	<select id="listAll" parameterType="pd" resultType="pd">
		select
		<include refid="Field"></include>
		from 
		<include refid="tableName"></include>
	</select>
	
	<!-- 批量删除 -->
	<delete id="deleteAll" parameterType="String">
		delete from
		<include refid="tableName"></include>
		where 
			INVOICE_ID in
		<foreach item="item" index="index" collection="array" open="(" separator="," close=")">
                 #{item}
		</foreach>
	</delete>
	
	<!-- da -->
</mapper>