<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="CouponMapper">

    <!--表名 -->
    <sql id="tableName">
		SHOP_COUPON
	</sql>

    <!-- 字段 -->
    <sql id="Field">
		COUPON_NAME,	
		COUPON_TYPE,	
		STARTTIME,	
		ENDTIME,	
		COUPON_PRICE,	
		USE_PRICE,	
		CHANGE_CODE,	
		COUPON_NUM,	
		ADDTIME,	
		COUPON_ID
	</sql>

    <!-- 字段值 -->
    <sql id="FieldValue">
		#{COUPON_NAME},	
		#{COUPON_TYPE},	
		#{STARTTIME},	
		#{ENDTIME},	
		#{COUPON_PRICE},	
		#{USE_PRICE},	
		#{CHANGE_CODE},	
		#{COUPON_NUM},	
		#{ADDTIME},	
		#{COUPON_ID}
	</sql>

    <!-- 新增-->
    <insert id="save" parameterType="pd">
        insert into
        <include refid="tableName"></include>
        (
        <include refid="Field"></include>
        ) values (
        <include refid="FieldValue"></include>
        )
    </insert>

    <!-- 删除-->
    <delete id="delete" parameterType="pd">
        delete from
        <include refid="tableName"></include>
        where
        COUPON_ID = #{COUPON_ID}
    </delete>

    <!-- 修改 -->
    <update id="edit" parameterType="pd">
        update
        <include refid="tableName"></include>
        set
        COUPON_NAME = #{COUPON_NAME},
        COUPON_TYPE = #{COUPON_TYPE},
        STARTTIME = #{STARTTIME},
        ENDTIME = #{ENDTIME},
        COUPON_PRICE = #{COUPON_PRICE},
        USE_PRICE = #{USE_PRICE},
        CHANGE_CODE = #{CHANGE_CODE},
        COUPON_NUM = #{COUPON_NUM},
        ADDTIME = #{ADDTIME},
        COUPON_ID = COUPON_ID
        where
        COUPON_ID = #{COUPON_ID}
    </update>

    <!-- 通过ID获取数据 -->
    <select id="findById" parameterType="pd" resultType="pd">
        select
        <include refid="Field"></include>
        from
        <include refid="tableName"></include>
        where
        COUPON_ID = #{COUPON_ID}
    </select>

    <!-- 列表 -->
    <select id="datalistPage" parameterType="page" resultType="pd">
        select
        <include refid="Field"></include>
        from
        <include refid="tableName"></include>
        where 1=1
        <!-- 关键词检索 -->
        <if test="pd.keywords!= null and pd.keywords != ''">
            and
            (
            COUPON_NAME LIKE CONCAT(CONCAT('%', #{pd.keywords}),'%')
            )
        </if>
        <!-- 开始时间 -->
        <if test="pd.lastStart != null and pd.lastStart !=''">
            and STARTTIME &gt;= #{pd.lastStart}
        </if>
        <!-- 结束时间 -->
        <if test="pd.lastEnd != null and pd.lastEnd !=''">
            and STARTTIME &lt;= #{pd.lastEnd}
        </if>
        <!-- 领取方式检索 -->
        <if test="pd.COUPON_TYPE != null and pd.COUPON_TYPE != ''">
            and COUPON_TYPE=#{pd.COUPON_TYPE}
        </if>
        <!-- 结束时间大于等于当前日期的优惠券 -->
        <if test="pd.CurrentTime != null and pd.CurrentTime !=''">
            and ENDTIME &gt;= #{pd.CurrentTime}
        </if>
        <!-- 会员账号未领取的优惠券 -->
        <if test="pd.USER_ID != null and pd.USER_ID !=''">
            and COUPON_ID not in (select COUPON_ID from SHOP_USERCOUPON where USER_ID = #{pd.USER_ID})
        </if>
    </select>

    <!-- 列表(全部) -->
    <select id="listAll" parameterType="pd" resultType="pd">
        select
        <include refid="Field"></include>
        from
        <include refid="tableName"></include>
    </select>

    <!-- 批量删除 -->
    <delete id="deleteAll" parameterType="String">
        delete from
        <include refid="tableName"></include>
        where
        COUPON_ID in
        <foreach item="item" index="index" collection="array" open="(" separator="," close=")">
            #{item}
        </foreach>
    </delete>

    <!-- da -->
</mapper>