<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="SupplierMapper">
	
	<!--表名 -->
	<sql id="tableName">
		SHOP_SUPPLIER
	</sql>
	
	<!-- 字段 -->
	<sql id="Field">
		SUPPLIER_SORT,	
		SUPPLIER_CODE,	
		SUPPLIER_NAME,	
		SUPPLIER_INDUSTRY,	
		SUPPLIER_ADDRESS,	
		SUPPLIER_POSTCODE,	
		SUPPLIER_TAXPAYER,	
		SUPPLIER_BANK,	
		SUPPLIER_BANKCODE,	
		SUPPLIER_LEGAL,	
		SUPPLIER_TELER,	
		SUPPLIER_TEL,	
		SUPPLIER_MEMO,	
		SUPPLIER_ID
	</sql>
	
	<!-- 字段值 -->
	<sql id="FieldValue">
		#{SUPPLIER_SORT},	
		#{SUPPLIER_CODE},	
		#{SUPPLIER_NAME},	
		#{SUPPLIER_INDUSTRY},	
		#{SUPPLIER_ADDRESS},	
		#{SUPPLIER_POSTCODE},	
		#{SUPPLIER_TAXPAYER},	
		#{SUPPLIER_BANK},	
		#{SUPPLIER_BANKCODE},	
		#{SUPPLIER_LEGAL},	
		#{SUPPLIER_TELER},	
		#{SUPPLIER_TEL},	
		#{SUPPLIER_MEMO},	
		#{SUPPLIER_ID}
	</sql>

	<!-- 数据字典地区表 -->
	<sql id="dictionariesTableName">
		SYS_DICTIONARIES
	</sql>
	
	<!-- 新增-->
	<insert id="save" parameterType="pd">
		insert into 
	<include refid="tableName"></include>
		(
	<include refid="Field"></include>
		) values (
	<include refid="FieldValue"></include>
		)
	</insert>
	
	<!-- 删除-->
	<delete id="delete" parameterType="pd">
		delete from
		<include refid="tableName"></include>
		where 
			SUPPLIER_ID = #{SUPPLIER_ID}
	</delete>
	
	<!-- 修改 -->
	<update id="edit" parameterType="pd">
		update
		<include refid="tableName"></include>
		set 
			SUPPLIER_SORT = #{SUPPLIER_SORT},
			SUPPLIER_CODE = #{SUPPLIER_CODE},
			SUPPLIER_NAME = #{SUPPLIER_NAME},
			SUPPLIER_INDUSTRY = #{SUPPLIER_INDUSTRY},
			SUPPLIER_ADDRESS = #{SUPPLIER_ADDRESS},
			SUPPLIER_POSTCODE = #{SUPPLIER_POSTCODE},
			SUPPLIER_TAXPAYER = #{SUPPLIER_TAXPAYER},
			SUPPLIER_BANK = #{SUPPLIER_BANK},
			SUPPLIER_BANKCODE = #{SUPPLIER_BANKCODE},
			SUPPLIER_LEGAL = #{SUPPLIER_LEGAL},
			SUPPLIER_TELER = #{SUPPLIER_TELER},
			SUPPLIER_TEL = #{SUPPLIER_TEL},
			SUPPLIER_MEMO = #{SUPPLIER_MEMO},
		SUPPLIER_ID = SUPPLIER_ID
		where 
		SUPPLIER_ID = #{SUPPLIER_ID}
	</update>
	
	<!-- 通过ID获取数据 -->
	<select id="findById" parameterType="pd" resultType="pd">
		select 
		<include refid="Field"></include>
		from 
		<include refid="tableName"></include>
		where 
			SUPPLIER_ID = #{SUPPLIER_ID}
	</select>
	
	<!-- 列表 -->
	<select id="datalistPage" parameterType="page" resultType="pd">
		select
		<include refid="Field"></include>,b.Name
		from 
		<include refid="tableName"></include> a,<include refid="dictionariesTableName"></include> b
		where a.SUPPLIER_SORT = b.DICTIONARIES_ID
		<if test="pd.supplier_sort != null and pd.supplier_sort != ''"><!-- 地区 -->
			and supplier_sort = #{pd.supplier_sort}
		</if>
		<if test="pd.keywords!= null and pd.keywords != ''"><!-- 关键词检索 -->
			and
				(
				<!--	根据需求自己加检索条件
					字段1 LIKE CONCAT(CONCAT('%', #{pd.keywords}),'%')
					 or 
					字段2 LIKE CONCAT(CONCAT('%', #{pd.keywords}),'%') 
				-->
				)
		</if>
	</select>
	
	<!-- 列表(全部) -->
	<select id="listAll" parameterType="pd" resultType="pd">
		select
		<include refid="Field"></include>
		from 
		<include refid="tableName"></include>
	</select>
	
	<!-- 批量删除 -->
	<delete id="deleteAll" parameterType="String">
		delete from
		<include refid="tableName"></include>
		where 
			SUPPLIER_ID in
		<foreach item="item" index="index" collection="array" open="(" separator="," close=")">
                 #{item}
		</foreach>
	</delete>
	
	<!-- da -->
</mapper>