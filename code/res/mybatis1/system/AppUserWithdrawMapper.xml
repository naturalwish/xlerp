<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="AppUserWithdrawMapper">
	
	<!--表名 -->
	<sql id="tableName">
		TB_APPUSERWITHDRAW
	</sql>
	
	<!-- 字段 -->
	<sql id="Field">
		USERID,	
		WITHDRAWTOTAL,	
		WITHDRAWDATE,	
		CHECKSTATUS,	
		CHECKUSERID,	
		CHECKDATE,	
		APPUSERWITHDRAW_ID
	</sql>
	
	<!-- 字段值 -->
	<sql id="FieldValue">
		#{USERID},	
		#{WITHDRAWTOTAL},	
		#{WITHDRAWDATE},	
		#{CHECKSTATUS},	
		#{CHECKUSERID},	
		#{CHECKDATE},	
		#{APPUSERWITHDRAW_ID}
	</sql>
	
	<!-- 新增-->
	<insert id="save" parameterType="pd">
		insert into 
	<include refid="tableName"></include>
		(
	<include refid="Field"></include>
		) values (
	<include refid="FieldValue"></include>
		)
	</insert>
	
	<!-- 删除-->
	<delete id="delete" parameterType="pd">
		delete from
		<include refid="tableName"></include>
		where 
			APPUSERWITHDRAW_ID = #{APPUSERWITHDRAW_ID}
	</delete>
	
	<!-- 修改 -->
	<update id="edit" parameterType="pd">
		update
		<include refid="tableName"></include>
		set
			CHECKSTATUS = #{CHECKSTATUS},
			CHECKUSERID = #{CHECKUSERID},
			CHECKDATE = #{CHECKDATE},
		APPUSERWITHDRAW_ID = APPUSERWITHDRAW_ID
		where 
		APPUSERWITHDRAW_ID = #{APPUSERWITHDRAW_ID}
	</update>
	
	<!-- 通过ID获取数据 -->
	<select id="findById" parameterType="pd" resultType="pd">
		select 
		<include refid="Field"></include>
		from 
		<include refid="tableName"></include>
		where 
			APPUSERWITHDRAW_ID = #{APPUSERWITHDRAW_ID}
	</select>

	<!-- 获得下线订单列表 -->
	<select id="SubUserOrderlist" parameterType="page" resultType="pd">
		select o.order_id,o.addtime,o.order_total,u.USERNAME,u.name from shop_order o
        left join sys_app_user u on o.user_id=u.USER_ID
        where  1 = 1
		<if test='pd.LEVEL == "1" or pd.LEVEL == "null" or pd.LEVEL == ""'>
			and  ifnull(LENGTH(u.INNER_CODE),0)= ifnull(LENGTH(#{pd.INNER_CODE}),0)+32 and u.INNER_CODE like concat(#{pd.INNER_CODE},'%')
		</if>
		<if test='pd.LEVEL == "2"'>
			and  ifnull(LENGTH(u.INNER_CODE),0) = ifnull(LENGTH(#{pd.INNER_CODE}),0)+64 and u.INNER_CODE like concat(#{pd.INNER_CODE},'%')
		</if>
		and o.status in (1,2,5,6)

	</select>
	
	<!-- 列表 -->
	<select id="datalistPage" parameterType="page" resultType="pd">
		select
		w.*,u.NAME,u.PHONE
		from
		TB_APPUSERWITHDRAW w
		left join SYS_APP_USER u on w.USERID= u.USER_ID
		where 1=1
		<!-- 根据用户ID查询  -->
		<if test="pd.USERID != null and pd.USERID !=''">
			and w.USERID = #{pd.USERID}
		</if>
	</select>
	
	<!-- 列表(全部) -->
	<select id="listAll" parameterType="pd" resultType="pd">
		select
		<include refid="Field"></include>
		from 
		<include refid="tableName"></include>
	</select>
	
	<!-- 批量删除 -->
	<delete id="deleteAll" parameterType="String">
		delete from
		<include refid="tableName"></include>
		where 
			APPUSERWITHDRAW_ID in
		<foreach item="item" index="index" collection="array" open="(" separator="," close=")">
                 #{item}
		</foreach>
	</delete>
	
	<!-- da -->
</mapper>